# ── Backend ──
# OBLIGATORIO: Clave JWT de al menos 32 caracteres. Generar con: openssl rand -base64 48
JWT_KEY=CAMBIAR_generar_clave_segura_con_openssl
# OBLIGATORIO: API Key segura
API_KEY=CAMBIAR_por_api_key_segura
# OBLIGATORIO: Credenciales de autenticación
AUTH_USER=CAMBIAR_usuario
AUTH_PASS=CAMBIAR_contraseña_segura

# ── Frontend ──
BACKEND_URL=http://backend:5000
NODE_ENV=production
