{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Security": {
    "ApiKey": "CONFIGURE_VIA_ENV_VARIABLE"
  },
  "Jwt": {
    "Issuer": "TaskService.Api",
    "Audience": "TaskService.Client",
    "ExpirationMinutes": "15"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 1,
    "QueueLimit": 2
  }
}
