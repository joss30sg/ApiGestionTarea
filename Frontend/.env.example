# Configuración de Variables de Entorno
# Frontend - React Native

# ========================================
# IMPORTANTE: COPIAR COMO .env.local
# ========================================
# Este es un archivo de EJEMPLO (.env.example)
# NO cometer a git los archivos .env.* con valores reales
# 
# Para desarrollo local:
#   cp .env.example .env.local
#

# ============================================
# Base URL de la API
# ============================================
# Desarrollo local (Android):
REACT_APP_API_URL=http://10.0.2.2:5000/api

# Desarrollo local (iOS):
# REACT_APP_API_URL=http://localhost:5000/api

# Staging:
# REACT_APP_API_URL=https://staging-api.example.com/api

# Producción:
# REACT_APP_API_URL=https://api.example.com/api


# ============================================
# API Key para Autenticación
# ============================================
# ⚠️  SEGURIDAD: Nunca hardcodear en el código
#
# Desarrollo:
REACT_APP_API_KEY=dev-key-123456

# Staging (obtener del administrador):
# REACT_APP_API_KEY=sk_staging_xxxxxxxxxxxxxxxx

# Producción (obtener del administrador, usar Secure Storage):
# REACT_APP_API_KEY=sk_prod_xxxxxxxxxxxxxxxx


# ============================================
# Entorno
# ============================================
# Valores: development, staging, production
REACT_APP_ENV=development

# Para staging:
# REACT_APP_ENV=staging

# Para producción:
# REACT_APP_ENV=production


# ============================================
# Logging
# ============================================
# Valores: debug, info, warn, error
REACT_APP_LOG_LEVEL=debug

# Para producción:
# REACT_APP_LOG_LEVEL=error


# ============================================
# Feature Flags (opcional)
# ============================================
# Habilitar/deshabilitar funcionalidades experimentales
REACT_APP_ENABLE_OFFLINE_MODE=true
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_DEBUG_MENU=true

# Para producción:
# REACT_APP_ENABLE_OFFLINE_MODE=false
# REACT_APP_ENABLE_ANALYTICS=true
# REACT_APP_ENABLE_DEBUG_MENU=false
